{
  "manifest_version": 3,
  "name": "VIGIL Phishing Detector",
  "version": "1.0",

  "permissions": ["activeTab", "scripting", "tabs"],

  "host_permissions": [
    "https://vigil-api-5sed.onrender.com/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  }
}